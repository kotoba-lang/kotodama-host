#:kotodama.host.config{:schema :kotodama.host.config/schema.v0,
                       :authority [:kotoba-clj :edn],
                       :format :toml,
                       :provider :edn-schema,
                       :provider-path
                       "resources/kotodama_host/config_schema.edn",
                       :root
                       [#:kotodama.host.config{:field :component,
                                               :type :section,
                                               :optional? true}
                        #:kotodama.host.config{:field :triggers,
                                               :type :section,
                                               :required? true}
                        #:kotodama.host.config{:field :yata,
                                               :type :section,
                                               :default :map}
                        #:kotodama.host.config{:field :pool,
                                               :type :section,
                                               :default :map}
                        #:kotodama.host.config{:field :static,
                                               :type :section,
                                               :optional? true}
                        #:kotodama.host.config{:field :extensions,
                                               :type :array-of-section,
                                               :default []}
                        #:kotodama.host.config{:field :interfaces,
                                               :type :section,
                                               :optional? true}],
                       :sections
                       {:interfaces
                        [#:kotodama.host.config{:field :package,
                                                :type :wit-package,
                                                :required? true}
                         #:kotodama.host.config{:field :provides,
                                                :type
                                                :array-of-section,
                                                :default []}
                         #:kotodama.host.config{:field :requires,
                                                :type
                                                :array-of-section,
                                                :default []}],
                        :pool
                        [#:kotodama.host.config{:field :size,
                                                :type :positive-int,
                                                :default 1}],
                        :functions
                        [#:kotodama.host.config{:field :name,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :params,
                                                :type :string,
                                                :default ""}
                         #:kotodama.host.config{:field :returns,
                                                :type :string,
                                                :default ""}],
                        :static
                        [#:kotodama.host.config{:field :prefix,
                                                :type :string,
                                                :required? true}],
                        :triggers
                        [#:kotodama.host.config{:field :http,
                                                :type :section,
                                                :optional? true}],
                        :component
                        [#:kotodama.host.config{:field :path,
                                                :type :path,
                                                :required? true}
                         #:kotodama.host.config{:field :env,
                                                :type :string-map,
                                                :default {}}],
                        :requires
                        [#:kotodama.host.config{:field :package,
                                                :type :wit-package,
                                                :required? true}
                         #:kotodama.host.config{:field :interface,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :functions,
                                                :type :string-vector,
                                                :default []}
                         #:kotodama.host.config{:field :provider,
                                                :type :string,
                                                :default ""}
                         #:kotodama.host.config{:field
                                                :preferred-tiers,
                                                :type :int-vector,
                                                :default []}
                         #:kotodama.host.config{:field
                                                :allow-tier-fallback,
                                                :type :boolean,
                                                :default true}],
                        :extensions
                        [#:kotodama.host.config{:field :name,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :package,
                                                :type :wit-package,
                                                :required? true}
                         #:kotodama.host.config{:field :component,
                                                :type :path,
                                                :required? true}
                         #:kotodama.host.config{:field :kinds,
                                                :type :string-vector,
                                                :default []}],
                        :http
                        [#:kotodama.host.config{:field :listen,
                                                :type :string,
                                                :default
                                                "0.0.0.0:8080"}
                         #:kotodama.host.config{:field :routes,
                                                :type :string-vector,
                                                :default []}
                         #:kotodama.host.config{:field :static-dir,
                                                :type :path,
                                                :optional? true}
                         #:kotodama.host.config{:field :spa,
                                                :type :boolean,
                                                :default false}],
                        :provides
                        [#:kotodama.host.config{:field :name,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :description,
                                                :type :string,
                                                :default ""}
                         #:kotodama.host.config{:field :functions,
                                                :type
                                                :array-of-section,
                                                :default []}
                         #:kotodama.host.config{:field :tags,
                                                :type :string-vector,
                                                :default []}
                         #:kotodama.host.config{:field :phase,
                                                :type :lifecycle-phase,
                                                :default "operational"}
                         #:kotodama.host.config{:field :tier,
                                                :type :positive-int,
                                                :default 2}
                         #:kotodama.host.config{:field
                                                :allowed-caller-tiers,
                                                :type :int-vector,
                                                :default []}
                         #:kotodama.host.config{:field :same-org-only,
                                                :type :boolean,
                                                :default false}
                         #:kotodama.host.config{:field :skill-prompt,
                                                :type :string,
                                                :default ""}],
                        :yata
                        [#:kotodama.host.config{:field :data-dir,
                                                :type :path,
                                                :default
                                                "./kotodama-data"}
                         #:kotodama.host.config{:field :graph-data-dir,
                                                :type :string,
                                                :default
                                                "./kotodama-data/graph"}
                         #:kotodama.host.config{:field
                                                :remote-endpoint,
                                                :type :string,
                                                :optional? true}
                         #:kotodama.host.config{:field :graph-uri,
                                                :type :string,
                                                :optional? true}
                         #:kotodama.host.config{:field
                                                :graph-max-nodes,
                                                :type
                                                :non-negative-int,
                                                :optional? true}
                         #:kotodama.host.config{:field
                                                :graph-max-edges,
                                                :type
                                                :non-negative-int,
                                                :optional? true}
                         #:kotodama.host.config{:field :s3,
                                                :type :section,
                                                :optional? true}
                         #:kotodama.host.config{:field :fuse,
                                                :type :boolean,
                                                :default false}],
                        :s3
                        [#:kotodama.host.config{:field :endpoint,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :bucket,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :key-id,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field
                                                :application-key,
                                                :type :string,
                                                :required? true}
                         #:kotodama.host.config{:field :region,
                                                :type :string,
                                                :default "us-west-004"}
                         #:kotodama.host.config{:field :prefix,
                                                :type :string,
                                                :default "yata/"}
                         #:kotodama.host.config{:field :eager,
                                                :type :boolean,
                                                :default false}]}}
